# Line-ending normalization (ADR 0027): all text files are LF in-repo and on checkout.
# CI runs on linux/amd64; LF is the canonical encoding for NFR-R4 byte-identical bake.
* text=auto eol=lf

# Git LFS patterns for NAIF SPICE kernel formats.
# (.tpc added in Story 1.3: NAIF "text PCK" kernels carry .tpc, not .pck, and the
# generic PCK kernel we ship is pck00011.tpc. Story 1.1 listed only *.pck; we
# include both to cover the file in `kernels/` under the AC4 LFS-tracked rule.)
*.bsp filter=lfs diff=lfs merge=lfs -text
*.bc filter=lfs diff=lfs merge=lfs -text
*.tf filter=lfs diff=lfs merge=lfs -text
*.tsc filter=lfs diff=lfs merge=lfs -text
*.tls filter=lfs diff=lfs merge=lfs -text
*.pck filter=lfs diff=lfs merge=lfs -text
*.tpc filter=lfs diff=lfs merge=lfs -text

# Self-hosted typography (Story 1.7). Subsetted .woff2 files under
# web/public/fonts/ are LFS-tracked: binary, opaque to diff. Total budget
# ~120 KB across three faces (JetBrains Mono, Inter, Source Serif 4).
*.woff2 filter=lfs diff=lfs merge=lfs -text

# Spacecraft GLB models (Story 1.12). Committed at web/public/models/voyager.glb
# at ~1.7 MB; full LOD chain (Story 4.3) will add larger variants.
*.glb filter=lfs diff=lfs merge=lfs -text

# Story 1.13 — equirectangular planet + skybox PNG textures live under
# web/public/textures/ at the 2k tier (~1 MB-class each). The pattern is
# scoped to that directory so smaller PNGs elsewhere in the repo (icons,
# favicons, screenshots) do not unexpectedly land in LFS. Story 4.3 lifts
# the deferral and adds the *.ktx2 patterns for 4K + 8K KTX2 (gas giants)
# and 2K KTX2 (moons), plus the textures-src/ tree for the upstream PNG
# sources that the build pipeline (web/scripts/build_textures.ts) transcodes.
web/public/textures/*.png filter=lfs diff=lfs merge=lfs -text
web/public/textures/*.ktx2 filter=lfs diff=lfs merge=lfs -text
web/textures-src/**/*.png filter=lfs diff=lfs merge=lfs -text
web/textures-src/**/*.jpg filter=lfs diff=lfs merge=lfs -text
web/textures-src/**/*.jpeg filter=lfs diff=lfs merge=lfs -text

# Story 6.1 — Golden Record audio bundle. AAC-LC `.m4a` placeholders live
# at `web/public/audio/golden-record/<chapter-slug>.m4a`. Real-procurement
# successor tracks land at the same paths via a future patch (the curation
# doc at `docs/audio/golden-record-curation.md` carries the procurement
# checklist). LFS-tracked from the start so the swap is a transparent
# in-place blob replace without rewriting history. Per-file budget is
# ~6 MB after real procurement; the current placeholders are ~32 KB each
# (silent AAC-LC, 90 s mono 96 kbps — exercises the playback chain end-to-
# end without shipping audible content). Voluntary Rule 12 disclosure: the
# bundle is well under both the 500 MB per-story and 250 MB single-file
# thresholds.
web/public/audio/**/*.m4a filter=lfs diff=lfs merge=lfs -text
