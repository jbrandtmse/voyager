# Line-ending normalization (ADR 0027): all text files are LF in-repo and on checkout.
# CI runs on linux/amd64; LF is the canonical encoding for NFR-R4 byte-identical bake.
* text=auto eol=lf

# Git LFS patterns for NAIF SPICE kernel formats.
# (.tpc added in Story 1.3: NAIF "text PCK" kernels carry .tpc, not .pck, and the
# generic PCK kernel we ship is pck00011.tpc. Story 1.1 listed only *.pck; we
# include both to cover the file in `kernels/` under the AC4 LFS-tracked rule.)
*.bsp filter=lfs diff=lfs merge=lfs -text
*.bc filter=lfs diff=lfs merge=lfs -text
*.tf filter=lfs diff=lfs merge=lfs -text
*.tsc filter=lfs diff=lfs merge=lfs -text
*.tls filter=lfs diff=lfs merge=lfs -text
*.pck filter=lfs diff=lfs merge=lfs -text
*.tpc filter=lfs diff=lfs merge=lfs -text
