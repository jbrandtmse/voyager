# BMad personal config (installer-managed, scoped to user)
_bmad/config.user.toml
_bmad/custom/config.user.toml

# Web (TypeScript / Vite) build artifacts
web/node_modules/
web/dist/
# Vite dep-optimization cache (regenerated on every `npm run dev`).
# The default web/.gitignore from create-vite predates this location move.
web/.vite/

# Bake (Python / uv) build artifacts
bake/.venv/
bake/__pycache__/
bake/tests/**/__pycache__/
bake/src/**/__pycache__/
# pytest cache dirs — defense in depth; pytest auto-ignores via inner .gitignore on first run
**/.pytest_cache/

# bake/out/ artifacts: list contents individually so we can carve out
# `l2-reference-fixtures.json` (committed for the web-side AC4 hook test
# in Story 1.6). Per git docs, `!` cannot re-include a path whose parent
# directory is ignored — so we ignore the binary subset by pattern instead
# of the whole directory.
bake/out/*.bin.br
bake/out/*.bin.br.part
bake/out/manifest.json
bake/out/manifest.json.part
bake/out/validation-report.md
# Story 3.3 — `web/scripts/build_glb.ts` emits this so
# `bake/src/manifest_writer.py` can merge the `models[]` section into
# `bake/out/manifest.json`. Regenerable via `just bake-glb`; not source.
bake/out/models-manifest-fragment.json
# Story 4.0 L2 attitude fixture — bake-side intermediate; the
# web-side canonical copy lives at `web/public/data/l2-attitude-fixture.json`
# (committed). Regenerable via `just bake-l2`.
bake/out/l2-attitude-fixture.json

# Web public/data — manifest.json is the runtime contract (committed). The
# brotli VTRJ binaries are regenerable via `just bake && just copy-bake-to-web`
# and stay ignored.
web/public/data/*.bin.br
web/public/data/*.bin.br.part

# OS noise
**/.DS_Store

# Story 1.13 scratch — temporary KTX-Software installer + libktx-web zip +
# Solar System Scope JPG source masters used during texture acquisition,
# plus a uv-managed Python 3.12 venv used briefly to probe pyktx. The
# committed PNG textures live under web/public/textures/.
.toolchain/
.ktx-venv/

# Story 5.3 — local cache of the NASA Planetary Photojournal source
# JPEGs that `web/scripts/build_pbd_plates.ts` downloads and crops into
# the six per-body PBD plates. The cropped + content-hashed PNGs under
# web/public/images/pbd/ ARE committed (they're the runtime asset);
# only the upstream-source-JPEG caches are gitignored — they're trivially
# re-downloaded via `npm run build-pbd-plates`. The caches live under
# web/textures-src/pbd-plates/ (NOT web/public/) so Vite does NOT copy
# them into the runtime bundle.
web/textures-src/pbd-plates/_pia*.jpg
