{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:og": "node --import tsx scripts/og-cards.ts",
    "build-glb": "node --import tsx scripts/build_glb.ts",
    "build-textures": "node --import tsx scripts/build_textures.ts",
    "build-pbd-plates": "node --import tsx scripts/build_pbd_plates.ts",
    "preview": "vite preview",
    "test": "vitest run --passWithNoTests",
    "test:visual": "playwright test --config tests/visual/playwright.config.ts",
    "test:visual:update": "playwright test --config tests/visual/playwright.config.ts --update-snapshots",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@gltf-transform/core": "^4.3.0",
    "@gltf-transform/extensions": "^4.3.0",
    "@gltf-transform/functions": "^4.3.0",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "^4.1.6",
    "draco3dgltf": "^1.5.7",
    "eslint": "^10.4.0",
    "happy-dom": "^20.9.0",
    "meshoptimizer": "^0.21.0",
    "prettier": "^3.8.3",
    "sharp": "^0.34.5",
    "tsx": "^4.22.3",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@types/three": "^0.184.1",
    "focus-trap": "^8.2.1",
    "lit": "^3.3.3",
    "three": "^0.184.0",
    "zod": "^4.4.3"
  }
}
